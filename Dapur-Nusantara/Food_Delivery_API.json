                        "body": {
                            "mode": "graphql",
                            "graphql": {
                                "query": "mutation CreateUser($name: String!, $email: String!, $password: String!, $address: String) {\n  createUser(name: $name, email: $email, password: $password, address: $address) {\n    id\n    name\n    email\n    address\n  }\n}",
                                "variables": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\",\n  \"address\": \"Jl. Sudirman No. 1, Jakarta\"\n}"
                            }
