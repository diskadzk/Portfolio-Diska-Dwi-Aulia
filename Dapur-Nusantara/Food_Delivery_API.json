                    "name": "Login User",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "graphql",
                            "graphql": {
                                "query": "mutation Login($email: String!, $password: String!) {\n  login(email: $email, password: $password) {\n    message\n    id\n    name\n    email\n    address\n  }\n}",
                                "variables": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
                            }
