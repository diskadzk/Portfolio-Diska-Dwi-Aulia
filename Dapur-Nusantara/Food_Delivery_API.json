                {
                    "name": "Create Order",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "graphql",
                            "graphql": {
                                "query": "mutation CreateOrder($userId: ID!, $menuId: ID!, $qty: Int!) {\n  createOrder(user_id: $userId, menu_id: $menuId, qty: $qty) {\n    id\n    order_id\n    user_id\n    menu_id\n    qty\n    total\n  }\n}",
                                "variables": "{\n  \"userId\": \"1\",\n  \"menuId\": \"1\",\n  \"qty\": 2\n}"
                            }
                        },
                        "url": {
                            "raw": "http://localhost:4000/graphql",
                            "protocol": "http",
                            "host": [
                                "localhost"
                            ],
                            "port": "4000",
                            "path": [
                                "graphql"
                            ]
                        },
                        "description": "Create a new order for a menu item"
                    }
                },
